{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "plugins": [{ "name": "@effect/language-service" }]
  },
  "include": ["plugins/**/*"]
}
