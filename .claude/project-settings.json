{
  "permissions": {
    "allow": [
      "WebFetch(domain:ui.shadcn.com)",
      "WebFetch(domain:www.better-auth.com)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gist.github.com)",
      "Bash(npx tsc:*)",
      "Bash(bunx tsc:*)",
      "Bash(bun pm ls:*)",
      "WebFetch(domain:effect.website)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:opentelemetry.io)",
      "WebFetch(domain:grafana.com)",
      "WebFetch(domain:effect-ts.github.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(bun test:*)",
      "Bash(node:*)",
      "Bash(bunx vitest:*)",
      "Bash(bun:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "mcp__serena__initial_instructions",
      "mcp__serena__activate_project"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/require-rtk.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks remind --client=claude-code"
          }
        ]
      },
      {
        "matcher": "mcp__serena__*",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks auto-approve --client=claude-code"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/agent-first-enforcement.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/post-edit-dirty-bit.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks activate --client=claude-code"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/developer-tests-pass.sh",
            "timeout": 180
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/feedback-loop-stop.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "serena-hooks cleanup --client=claude-code"
          }
        ]
      }
    ]
  }
}
